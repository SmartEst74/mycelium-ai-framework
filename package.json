{
  "name": "@mycelium/ai-framework",
  "version": "0.2.0",
  "description": "Colonial AI agent orchestration with event-sourced shared memory",
  "type": "module",
  "main": "src/mycelium.mjs",
  "bin": { "mycelium": "src/cli.mjs" },
  "scripts": {
    "start": "node --experimental-sqlite src/cli.mjs",
    "test": "node --experimental-sqlite --test ./tests/test.mjs",
    "bench": "node --experimental-sqlite benchmarks/colonial_memory_bench.mjs",
    "health": "node --experimental-sqlite src/cli.mjs health",
    "mission": "node --experimental-sqlite src/cli.mjs mission"
  },
  "engines": { "node": ">=22" },
  "keywords": ["ai", "agents", "orchestration", "openclaw", "memory"],
  "license": "MIT"
}
